# ---------------------------------------------------------------------------
# Castio environment variables
# ---------------------------------------------------------------------------
# Castio builds and serves all public pages WITHOUT these set. The dashboard
# shows a clean setup notice until Supabase is configured. Auth + saving data
# require a real Supabase project.
#
# Copy this file to `.env.local` and fill in the values.

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Public origin. Used for canonical URLs, OpenGraph tags and embed snippets.
# In production set this to your deployed URL, e.g. https://castio.co
NEXT_PUBLIC_SITE_URL=http://localhost:3000
